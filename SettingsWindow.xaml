<Window x:Class="ProPresenterTimer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProPresenter Timer Settings"
        Width="580" Height="640"
        MinWidth="520" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F2F2F2">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#E8E8E8" Padding="24,18" BorderBrush="#22000000" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBlock Text="ProPresenter Timer Settings" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
      <StackPanel>
        <TextBlock Text="Side Screen  ·  Required" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10"/>
        <Border Background="#E6FFFFFF" CornerRadius="16" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
          <StackPanel>
            <DockPanel LastChildFill="True" Margin="0,0,0,8">
              <TextBlock Text="Source" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
              <TextBlock Text="ProPresenter" Foreground="#107C10" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <Separator Margin="0,4"/>
            <DockPanel LastChildFill="True" Margin="0,8,0,0">
              <TextBlock Text="Display Label" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
              <TextBox x:Name="TxtSideLabel" Padding="8"/>
            </DockPanel>
            <Separator Margin="0,12"/>
            <DockPanel LastChildFill="True">
              <TextBlock Text="IP Address" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
              <TextBox x:Name="TxtSideIp" Padding="8"/>
            </DockPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="Side Screen Audio  ·  Optional" FontWeight="SemiBold" FontSize="15" Margin="0,22,0,10"/>
        <Border Background="#E6FFFFFF" CornerRadius="16" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
          <StackPanel>
            <DockPanel LastChildFill="True">
              <TextBlock Text="Enable" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
              <CheckBox x:Name="ChkAudio" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <TextBlock Text="Optional separate base URL for audio (second ProPresenter)." FontSize="11" Foreground="#888" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>
            <StackPanel x:Name="AudioFields" Margin="0,10,0,0" Visibility="Collapsed">
              <Separator Margin="0,4"/>
              <DockPanel LastChildFill="True" Margin="0,8,0,0">
                <TextBlock Text="Display Label" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtAudioLabel" Padding="8"/>
              </DockPanel>
              <DockPanel LastChildFill="True" Margin="0,10,0,0">
                <TextBlock Text="Audio IP (opt.)" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtAudioIp" Padding="8"/>
              </DockPanel>
              <TextBlock Text="Leave blank to use the Side Screen IP (same ProPresenter)." FontSize="11" Foreground="#888" Margin="120,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="Center Screen / LED  ·  Optional" FontWeight="SemiBold" FontSize="15" Margin="0,22,0,10"/>
        <Border Background="#E6FFFFFF" CornerRadius="16" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
          <StackPanel>
            <DockPanel LastChildFill="True">
              <TextBlock Text="Enable" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
              <CheckBox x:Name="ChkCenter" VerticalAlignment="Center"/>
            </DockPanel>
            <StackPanel x:Name="CenterFields" Margin="0,10,0,0" Visibility="Collapsed">
              <Separator Margin="0,4"/>
              <DockPanel LastChildFill="True" Margin="0,8,0,0">
                <TextBlock Text="Display Label" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtCenterLabel" Padding="8"/>
              </DockPanel>
              <DockPanel LastChildFill="True" Margin="0,10,0,0">
                <TextBlock Text="IP Address" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtCenterIp" Padding="8"/>
              </DockPanel>
              <DockPanel LastChildFill="True" Margin="0,10,0,0">
                <TextBlock Text="Source" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbCenterMode" SelectedIndex="0">
                  <ComboBoxItem Content="ProPresenter"/>
                  <ComboBoxItem Content="Resolume"/>
                </ComboBox>
              </DockPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="Advanced" FontWeight="SemiBold" FontSize="15" Margin="0,22,0,10"/>
        <Border Background="#E6FFFFFF" CornerRadius="16" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
          <DockPanel LastChildFill="True">
            <TextBlock Text="Timeout (ms)" Width="120" DockPanel.Dock="Left" Foreground="#666" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtTimeout" Padding="8"/>
          </DockPanel>
        </Border>

        <TextBlock x:Name="TxtValidation" Text="Side Screen IP address is required." Foreground="#CA5010"
                   FontSize="12" Margin="0,16,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#E8E8E8" BorderBrush="#22000000" BorderThickness="0,1,0,0" Padding="24,14">
      <DockPanel LastChildFill="False">
        <Button Content="Cancel" Width="90" Height="32" Margin="0,0,10,0" Click="Cancel_OnClick" IsCancel="True"/>
        <Button x:Name="BtnSave" Content="Save" Width="90" Height="32" DockPanel.Dock="Right"
                Click="Save_OnClick" IsDefault="True" FontWeight="SemiBold"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
