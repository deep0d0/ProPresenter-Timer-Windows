<Window x:Class="ProPresenterTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProPresenter Timer"
        Width="1200" Height="800"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="Transparent">
  <Window.Resources>
    <Storyboard x:Key="PulseCritical" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="GlowSide" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.65" Duration="0:0:0.5"/>
    </Storyboard>
    <Storyboard x:Key="PulseWarning" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="GlowSide" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.35" Duration="0:0:1"/>
    </Storyboard>
    <Storyboard x:Key="PulseNormal">
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleX"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="ScaleSide" Storyboard.TargetProperty="ScaleY"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="GlowSide" Storyboard.TargetProperty="Opacity"
                       To="0" Duration="0:0:0.25"/>
    </Storyboard>
    <!-- Center card -->
    <Storyboard x:Key="PulseCriticalCenter" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="GlowCenter" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.65" Duration="0:0:0.5"/>
    </Storyboard>
    <Storyboard x:Key="PulseWarningCenter" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="GlowCenter" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.35" Duration="0:0:1"/>
    </Storyboard>
    <Storyboard x:Key="PulseNormalCenter">
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleX"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="ScaleCenter" Storyboard.TargetProperty="ScaleY"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="GlowCenter" Storyboard.TargetProperty="Opacity"
                       To="0" Duration="0:0:0.25"/>
    </Storyboard>
    <!-- Audio card -->
    <Storyboard x:Key="PulseCriticalAudio" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.05" Duration="0:0:0.5"/>
      <DoubleAnimation Storyboard.TargetName="GlowAudio" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.65" Duration="0:0:0.5"/>
    </Storyboard>
    <Storyboard x:Key="PulseWarningAudio" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleX"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleY"
                       From="1" To="1.02" Duration="0:0:1"/>
      <DoubleAnimation Storyboard.TargetName="GlowAudio" Storyboard.TargetProperty="Opacity"
                       From="0" To="0.35" Duration="0:0:1"/>
    </Storyboard>
    <Storyboard x:Key="PulseNormalAudio">
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleX"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="ScaleAudio" Storyboard.TargetProperty="ScaleY"
                       To="1" Duration="0:0:0.25"/>
      <DoubleAnimation Storyboard.TargetName="GlowAudio" Storyboard.TargetProperty="Opacity"
                       To="0" Duration="0:0:0.25"/>
    </Storyboard>
  </Window.Resources>

  <Border x:Name="RootBorder" CornerRadius="0">
    <Grid>
      <Grid x:Name="BackgroundHost"/>

      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    Padding="40" PanningMode="VerticalOnly">
        <StackPanel x:Name="CardStack" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="1400">
          <!-- Center card -->
          <Border x:Name="CardCenter" Margin="0,0,0,20" Padding="36,28" CornerRadius="28"
                  BorderThickness="1" Visibility="Collapsed">
            <Border.Background>
              <SolidColorBrush Color="#40FFFFFF"/>
            </Border.Background>
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="CardCenterBorder0" Color="#40FFFFFF" Offset="0"/>
                <GradientStop x:Name="CardCenterBorder1" Color="#14FFFFFF" Offset="1"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
              <DropShadowEffect x:Name="CardCenterShadow" BlurRadius="20" ShadowDepth="6" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            <StackPanel>
              <TextBlock x:Name="LblCenter" FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display, Segoe UI"
                         Foreground="#A0FFFFFF" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
              <Viewbox StretchDirection="DownOnly" MaxHeight="160" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <TextBlock x:Name="TxtCenter" FontSize="120" FontWeight="Bold" FontFamily="Cascadia Mono, Consolas"
                           HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                  <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="ScaleCenter"/>
                  </TextBlock.RenderTransform>
                  <TextBlock.Effect>
                    <DropShadowEffect x:Name="GlowCenter" Color="White" BlurRadius="20" Opacity="0" ShadowDepth="0"/>
                  </TextBlock.Effect>
                </TextBlock>
              </Viewbox>
            </StackPanel>
          </Border>

          <!-- Side video -->
          <Border x:Name="CardSide" Margin="0,0,0,20" Padding="36,28" CornerRadius="28"
                  BorderThickness="1">
            <Border.Background>
              <SolidColorBrush Color="#40FFFFFF"/>
            </Border.Background>
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="CardSideBorder0" Color="#40FFFFFF" Offset="0"/>
                <GradientStop x:Name="CardSideBorder1" Color="#14FFFFFF" Offset="1"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
              <DropShadowEffect x:Name="CardSideShadow" BlurRadius="20" ShadowDepth="6" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            <StackPanel>
              <TextBlock x:Name="LblSide" FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display, Segoe UI"
                         Foreground="#A0FFFFFF" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
              <Viewbox StretchDirection="DownOnly" MaxHeight="160" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <TextBlock x:Name="TxtSide" FontSize="120" FontWeight="Bold" FontFamily="Cascadia Mono, Consolas"
                           HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                  <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="ScaleSide"/>
                  </TextBlock.RenderTransform>
                  <TextBlock.Effect>
                    <DropShadowEffect x:Name="GlowSide" Color="White" BlurRadius="20" Opacity="0" ShadowDepth="0"/>
                  </TextBlock.Effect>
                </TextBlock>
              </Viewbox>
            </StackPanel>
          </Border>

          <!-- Side audio -->
          <Border x:Name="CardAudio" Margin="0,0,0,0" Padding="36,28" CornerRadius="28"
                  Visibility="Collapsed" BorderThickness="1">
            <Border.Background>
              <SolidColorBrush Color="#40FFFFFF"/>
            </Border.Background>
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="CardAudioBorder0" Color="#40FFFFFF" Offset="0"/>
                <GradientStop x:Name="CardAudioBorder1" Color="#14FFFFFF" Offset="1"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
              <DropShadowEffect x:Name="CardAudioShadow" BlurRadius="20" ShadowDepth="6" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="#A0FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="LblAudio" FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display, Segoe UI"
                           Foreground="#A0FFFFFF" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
              </StackPanel>
              <Viewbox StretchDirection="DownOnly" MaxHeight="160" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <TextBlock x:Name="TxtAudio" FontSize="120" FontWeight="Bold" FontFamily="Cascadia Mono, Consolas"
                           HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                  <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="ScaleAudio"/>
                  </TextBlock.RenderTransform>
                  <TextBlock.Effect>
                    <DropShadowEffect x:Name="GlowAudio" Color="White" BlurRadius="20" Opacity="0" ShadowDepth="0"/>
                  </TextBlock.Effect>
                </TextBlock>
              </Viewbox>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Button x:Name="BtnSettings" HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="40" Width="44" Height="44" Cursor="Hand"
              Click="BtnSettings_OnClick" ToolTip="Settings"
              Background="#33FFFFFF" BorderThickness="0">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" CornerRadius="22" Background="{TemplateBinding Background}">
              <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#99FFFFFF"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="#55FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
      </Button>
    </Grid>
  </Border>
</Window>
